{
  "name": "codex-channel-electron",
  "version": "1.2.0",
  "private": true,
  "description": "Codex channel switch desktop app",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "dev:main": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:renderer": "vite --config vite.config.ts --host 127.0.0.1 --port 5173",
    "dev:electron:run": "cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "dev:electron": "wait-on tcp:5173 file:dist/main.js file:dist/preload.js && nodemon --watch dist/main.js --watch dist/preload.js --ext js --exec \"npm run dev:electron:run\"",
    "dev": "npm run clean && concurrently -k -n MAIN,RENDERER,ELECTRON -c yellow,cyan,green \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "deploy:desktop": "bash ./scripts/deploy-desktop-app.sh",
    "deploy:desktop:open": "bash ./scripts/deploy-desktop-app.sh --open",
    "build:deploy:desktop": "npm run pack && bash ./scripts/deploy-desktop-app.sh --skip-pack",
    "build:deploy:desktop:open": "npm run pack && bash ./scripts/deploy-desktop-app.sh --skip-pack --open",
    "hooks:install": "bash ./scripts/setup-git-hooks.sh",
    "hooks:uninstall": "git config --unset core.hooksPath || true",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "build": {
    "appId": "com.codex.channel.electron",
    "productName": "codex channel",
    "asar": true,
    "icon": "build-assets/codex.icns",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "icon": "build-assets/codex.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ]
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.9",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@douyinfe/semi-illustrations": "^2.94.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.97.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  }
}
